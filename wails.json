{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "fbe-go",
  "outputfilename": "fbe",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "Dmitry Gordiyevsky",
    "email": "dimgord@gmail.com"
  },
  "info": {
    "productName": "FictionBook Editor (Go)",
    "productVersion": "1.0.2",
    "copyright": "© 2026",
    "comments": "FB2 editor — Go + Wails port of classic FBE",
    "fileAssociations": [
      {
        "ext": "fb2",
        "name": "FictionBook 2.x document",
        "description": "FB2 e-book",
        "iconName": "iconfile",
        "role": "Editor"
      }
    ]
  }
}
